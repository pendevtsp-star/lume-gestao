# Lume Gestao - exemplo de ambiente para VPS Linux
# Copie este arquivo para `.env` na VPS e troque todos os placeholders.
# Nao versionar `.env` real.
#
# Dominios reais usados na producao:
# clinicafisiolume.com.br
# sistema.clinicafisiolume.com.br
#
# Cloudflare:
# - Inicialmente mantenha o DNS como "DNS only" ate Nginx e HTTPS estarem funcionando.
# - Depois ative o proxy e use SSL/TLS em Full (strict).
# - O servidor tambem precisa responder HTTPS com certificado valido.
# - Use proxy reverso Nginx apontando para 127.0.0.1:8000.

# Ambiente Django
ENVIRONMENT=production
DEBUG=False
LUME_STRICT_PRODUCTION=True
SECRET_KEY=troque-por-uma-chave-aleatoria-com-mais-de-50-caracteres
ALLOWED_HOSTS=clinicafisiolume.com.br,www.clinicafisiolume.com.br,sistema.clinicafisiolume.com.br
CSRF_TRUSTED_ORIGINS=https://clinicafisiolume.com.br,https://www.clinicafisiolume.com.br,https://sistema.clinicafisiolume.com.br
PUBLIC_BASE_URL=https://sistema.clinicafisiolume.com.br
SYSTEM_BASE_URL=https://sistema.clinicafisiolume.com.br
WEBSITE_BASE_URL=https://clinicafisiolume.com.br
SYSTEM_HOSTS=sistema.clinicafisiolume.com.br
WEBSITE_HOSTS=clinicafisiolume.com.br,www.clinicafisiolume.com.br
LUME_HEALTHCHECK_HOST=sistema.clinicafisiolume.com.br

# Banco PostgreSQL
DB_ENGINE=postgres
POSTGRES_DB=lume
POSTGRES_USER=lume
POSTGRES_PASSWORD=troque-por-uma-senha-forte-do-postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Arquivos persistentes dentro do container
# No docker-compose.prod.yml, estes caminhos recebem volumes/diretorios persistentes.
STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media

# HTTPS atras de Nginx/Cloudflare
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
USE_X_FORWARDED_HOST=True

# API REST
# Basic Auth deve continuar False em producao.
# Token Auth prepara o caminho para app mobile futuro.
REST_ENABLE_BASIC_AUTH=False
REST_ENABLE_TOKEN_AUTH=True
REST_ENABLE_THROTTLING=True
REST_ANON_THROTTLE_RATE=30/min
REST_USER_THROTTLE_RATE=1000/hour

# Dados demo e usuario tecnico
LUME_SEED_DEMO=False
LUME_MAINTENANCE_USER_ENABLED=False
LUME_MAINTENANCE_USERNAME=root
LUME_MAINTENANCE_PASSWORD=
LUME_MAINTENANCE_ROTATE_PASSWORD=False

# Inicializacao e Gunicorn
LUME_RUN_MIGRATIONS_ON_START=True
LUME_WORKER_RUN_MIGRATIONS=False
LUME_GUNICORN_WORKERS=3
LUME_GUNICORN_TIMEOUT=120

# Worker de tarefas recorrentes
LUME_JOB_INTERVAL_SECONDS=60
LUME_QUEUE_BATCH_SIZE=50

# Backups
# O backup local e feito por scripts/backup-production.sh.
# Para enviar copia externa, instale/configure rclone na VPS e aponte BACKUP_RCLONE_REMOTE.
BACKUP_DIR=backups
RETENTION_DAYS=14
BACKUP_UPLOAD_ENABLED=False
BACKUP_RCLONE_REMOTE=remote:lume-gestao/backups
BACKUP_RCLONE_FLAGS=--transfers 2 --checkers 4

# Logs em Docker
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# E-mail SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=Lume Gestao <nao-responda@clinicafisiolume.com.br>
EMAIL_TRANSACTIONAL_FROM_EMAIL=Lume Gestao <nao-responda@clinicafisiolume.com.br>
EMAIL_MARKETING_FROM_EMAIL=Lume Studio <contato@clinicafisiolume.com.br>
EMAIL_REPLY_TO=contato@clinicafisiolume.com.br
EMAIL_BREVO_WEBHOOK_TOKEN=gere-um-token-aleatorio-longo
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=seu-login-brevo
EMAIL_HOST_PASSWORD=sua-chave-smtp-brevo
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=15

# Google Calendar
GOOGLE_CALENDAR_CLIENT_ID=cole-o-client-id-google
GOOGLE_CALENDAR_CLIENT_SECRET=cole-o-client-secret-google
GOOGLE_CALENDAR_TIMEOUT=15
GOOGLE_CALENDAR_SYNC_ENABLED=True

# WhatsApp Meta API
# Mantenha WHATSAPP_DRY_RUN=True ate validar conta, templates e numero.
WHATSAPP_PROVIDER=meta
WHATSAPP_DRY_RUN=True
WHATSAPP_META_API_VERSION=v23.0
WHATSAPP_META_ACCESS_TOKEN=cole-o-token-da-meta
WHATSAPP_META_PHONE_NUMBER_ID=cole-o-phone-number-id
WHATSAPP_EMBEDDED_APP_ID=cole-o-meta-app-id
WHATSAPP_EMBEDDED_CONFIG_ID=cole-o-meta-configuration-id
WHATSAPP_EMBEDDED_APP_SECRET=cole-o-meta-app-secret
WHATSAPP_WEBHOOK_VERIFY_TOKEN=crie-um-token-forte-se-ativar-webhook
WHATSAPP_WEB_GATEWAY_URL=http://whatsapp-web:3020
WHATSAPP_WEB_GATEWAY_TOKEN=
WHATSAPP_TIMEOUT=15

# Chave futura para criptografia de campos sensiveis em banco.
# Use valor forte e guarde fora do Git antes de ativar criptografia de campo.
LUME_FIELD_ENCRYPTION_KEY=gere-uma-chave-forte-fora-do-git

# Asaas
# Use sandbox/dry-run no inicio. O webhook publico do checkout geral e:
# https://sistema.clinicafisiolume.com.br/checkout/webhooks/asaas/
ASAAS_DRY_RUN=True
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=cole-a-chave-do-asaas
ASAAS_WEBHOOK_TOKEN=crie-um-token-forte-para-o-webhook
ASAAS_TIMEOUT=20

# Checkout geral de planos e mensalidades
# Mantenha False ate finalizar homologacao em sandbox e compra teste.
CHECKOUT_ENABLED=False
CHECKOUT_PUBLIC_ENABLED=False
CHECKOUT_PATIENT_ENABLED=False
CHECKOUT_WEBHOOK_ENABLED=False
CHECKOUT_PAYMENT_PROVIDER=asaas
CHECKOUT_REQUIRE_MERCHANT_ACCOUNT=True

# Lume em casa / Fisioterapia em Casa
# Liberacao inicial: acesso incluido para pacientes ativos e usuarios internos.
# Compras/assinaturas do canal ficam preservadas no codigo, mas desligadas ate homologacao comercial.
HOMECARE_ENABLED=True
HOMECARE_INTERNAL_ENABLED=True
HOMECARE_PUBLIC_ENABLED=True
HOMECARE_CHECKOUT_ENABLED=False
HOMECARE_WEBHOOK_ENABLED=False
HOMECARE_UPLOAD_WORKER_ENABLED=True
HOMECARE_PAYMENT_PROVIDER=asaas
HOMECARE_VIDEO_PROVIDER=local
HOMECARE_MAX_UPLOAD_MB=1024
HOMECARE_UPLOAD_BATCH_SIZE=3
HOMECARE_LOCAL_VIDEO_ACCEL_REDIRECT=True
HOMECARE_LOCAL_VIDEO_ACCEL_PREFIX=/protected-homecare-media/
BUNNY_STREAM_DRY_RUN=True
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_TIMEOUT=30

# Lume Connect - compartilhar nas redes
# Nesta versao, nao ha publicacao automatica no Instagram/Meta.
# O fluxo seguro e: gerar/copiar legenda, baixar imagem e publicar manualmente pelo celular.
LUME_CONNECT_ENABLED=True
LUME_CONNECT_MAX_IMAGE_MB=8
LUME_CONNECT_MAX_VIDEO_MB=80
LUME_CONNECT_MAX_SHORT_VIDEO_SECONDS=60
LUME_CONNECT_FFMPEG_PATH=ffmpeg
LUME_CONNECT_FFPROBE_PATH=ffprobe
LUME_CONNECT_FFMPEG_TIMEOUT_SECONDS=120
LUME_CONNECT_TRANSCODE_MAX_WIDTH=720
LUME_CONNECT_TRANSCODE_CRF=28
LUME_CONNECT_TRANSCODE_PRESET=veryfast
LUME_CONNECT_TRANSCODE_AUDIO_BITRATE=96k
AI_CAPTION_ENABLED=False
AI_PROVIDER=
AI_API_KEY=
AI_CAPTION_MODEL=
