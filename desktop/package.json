{
  "name": "lume-gestao-desktop",
  "version": "0.1.0",
  "description": "Aplicativo desktop do Lume Gestao.",
  "homepage": "https://github.com/pendevtsp-star/lume-gestao",
  "author": {
    "name": "Lume Studio",
    "email": "suporte@lume.local"
  },
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "electron-updater": "^6.6.2"
  },
  "build": {
    "appId": "br.com.lume.gestao",
    "productName": "Lume Gestao",
    "copyright": "Copyright © 2026 Lume Studio",
    "directories": {
      "output": "../dist/desktop",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "pendevtsp-star",
        "repo": "lume-gestao",
        "releaseType": "release"
      }
    ],
    "artifactName": "${productName} ${version}.${ext}",
    "files": [
      "main.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend-bin",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "icon": "build/icon.png",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": "dmg",
      "category": "public.app-category.business",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "maintainer": "Lume Studio <suporte@lume.local>"
    }
  }
}
